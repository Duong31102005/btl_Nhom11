@model QLPhongHoc.Models.PhongHoc
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chi Tiết Phòng Học";
    ViewData["ActivePage"] = "PhongHoc";
    ViewData["PageTitle"] = "Chi tiết: " + Model.TenPhong;
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Chi tiết phòng học</h1>
        <p>Xem thông tin đầy đủ về phòng @Model.MaPhong</p>
    </div>
    <div class="page-header-actions">
        <a href="@Url.Action("Edit", new { id = Model.MaPhong })" class="btn btn-primary">
            <span>✏️ Chỉnh Sửa</span>
        </a>
    </div>
</div>

<!-- Detail Card -->
<div class="card" style="max-width:800px;">
    <div class="card-header">
        <div class="card-title">
            <span>@Model.TenPhong</span>
        </div>
        <div>
            @if (Model.TrangThai == "Trống")
            {
                <span class="badge badge-success">✓ Trống</span>
            }
            else if (Model.TrangThai == "Đang sử dụng")
            {
                <span class="badge badge-info">● Đang sử dụng</span>
            }
            else if (Model.TrangThai == "Đang bảo trì")
            {
                <span class="badge badge-warning">⚙ Đang bảo trì</span>
            }
            else if (Model.TrangThai == "Ngừng sử dụng")
            {
                <span class="badge badge-outline">✕ Ngừng sử dụng</span>
            }
        </div>
    </div>
    <div class="card-body">
        <div class="detail-grid">
            <!-- Left Column -->
            <div>
                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Mã Phòng</div>
                    <div class="detail-value">@Model.MaPhong</div>
                </div>

                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Dãy Nhà</div>
                    <div class="detail-value">@Model.DayNha</div>
                </div>

                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Tầng</div>
                    <div class="detail-value">Tầng @Model.Tang</div>
                </div>
            </div>

            <!-- Right Column -->
            <div>
                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Loại Phòng</div>
                    <div class="detail-value">@Model.LoaiPhong</div>
                </div>

                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Sức Chứa</div>
                    <div class="detail-value">@Model.SucChua người</div>
                </div>

                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Trạng Thái</div>
                    <div class="detail-value">@Model.TrangThai</div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.GhiChu))
        {
            <div class="divider"></div>
            <div class="form-group">
                <div class="detail-label" style="margin-bottom:var(--space-3);">Ghi Chú</div>
                <div style="background:var(--bg-canvas);padding:var(--space-4);border-radius:var(--radius-md);border-left:3px solid var(--primary-blue);font-size:14px;line-height:1.6;">
                    @Model.GhiChu
                </div>
            </div>
        }
    </div>
    <div class="card-footer">
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <span>← Quay Lại</span>
        </a>
    </div>
</div>
