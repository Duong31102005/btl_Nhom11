@model QLPhongHoc.Models.PhongHoc
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Thêm Phòng Học";
    ViewData["ActivePage"] = "PhongHoc";
    ViewData["PageTitle"] = "Thêm Phòng Học Mới";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Thêm phòng học mới</h1>
        <p>Điền đầy đủ thông tin để tạo một phòng học mới</p>
    </div>
</div>

<!-- Form Card -->
<div class="form-card card">
    <div class="card-body">
        @if (TempData["Error"] != null)
        {
            <div style="background:var(--accent-danger-bg);border-left:4px solid var(--accent-danger);padding:var(--space-4);border-radius:var(--radius-md);margin-bottom:var(--space-6);">
                <div style="color:var(--accent-danger);font-weight:600;">⚠️ Lỗi</div>
                <div style="color:var(--accent-danger);font-size:13px;margin-top:var(--space-1);">@TempData["Error"]</div>
            </div>
        }

        <form asp-action="Create" method="post" novalidate>
            <!-- Thông tin cơ bản -->
            <div class="form-section-title">Thông tin cơ bản</div>

            <div class="form-group">
                <label class="form-label" for="tenPhong">
                    Tên phòng <span style="color:var(--accent-danger);">*</span>
                </label>
                <input 
                    asp-for="TenPhong" 
                    class="form-control" 
                    id="tenPhong"
                    placeholder="VD: Phòng L301, A101"
                    required />
                <span asp-validation-for="TenPhong" class="form-text error"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);margin-bottom:var(--space-6);">
                <div class="form-group">
                    <label class="form-label" for="dayNha">
                        Dãy nhà <span style="color:var(--accent-danger);">*</span>
                    </label>
                    <input 
                        asp-for="DayNha" 
                        class="form-control" 
                        id="dayNha"
                        placeholder="VD: A, B, L"
                        required />
                    <span asp-validation-for="DayNha" class="form-text error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="tang">
                        Tầng <span style="color:var(--accent-danger);">*</span>
                    </label>
                    <input 
                        asp-for="Tang" 
                        class="form-control" 
                        id="tang"
                        type="number" 
                        min="1"
                        placeholder="1, 2, 3..."
                        required />
                    <span asp-validation-for="Tang" class="form-text error"></span>
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);margin-bottom:var(--space-6);">
                <div class="form-group">
                    <label class="form-label" for="sucChua">
                        Sức chứa <span style="color:var(--accent-danger);">*</span>
                    </label>
                    <input 
                        asp-for="SucChua" 
                        class="form-control" 
                        id="sucChua"
                        type="number" 
                        min="1"
                        placeholder="30, 50, 80..."
                        required />
                    <span asp-validation-for="SucChua" class="form-text error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="loaiPhong">
                        Loại phòng <span style="color:var(--accent-danger);">*</span>
                    </label>
                    <select asp-for="LoaiPhong" class="form-control" id="loaiPhong" required>
                        <option value="">-- Chọn loại phòng --</option>
                        <option value="Lý thuyết">Lý thuyết</option>
                        <option value="Thực hành">Thực hành</option>
                        <option value="Seminar">Seminar</option>
                    </select>
                    <span asp-validation-for="LoaiPhong" class="form-text error"></span>
                </div>
            </div>

            <!-- Ghi chú -->
            <div class="form-section-title" style="margin-top:var(--space-8);">Thêm chi tiết</div>

            <div class="form-group">
                <label class="form-label" for="ghiChu">Ghi chú</label>
                <textarea 
                    asp-for="GhiChu" 
                    class="form-control" 
                    id="ghiChu"
                    placeholder="Nhập thông tin bổ sung về phòng học..."
                    rows="4"></textarea>
                <span asp-validation-for="GhiChu" class="form-text"></span>
            </div>

            <!-- Actions -->
            <div class="card-footer" style="margin-top:var(--space-8);border:none;background:none;padding:0;">
                <button type="submit" class="btn btn-primary">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                        <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <polyline points="17 21 17 13 7 13 7 21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Lưu Phòng Học</span>
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <span>Hủy</span>
                </a>
            </div>
        </form>
    </div>
</div>
