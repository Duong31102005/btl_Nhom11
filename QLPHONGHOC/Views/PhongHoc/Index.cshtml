@model IEnumerable<QLPhongHoc.Models.PhongHoc>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý Phòng Học";
    ViewData["ActivePage"] = "PhongHoc";
    ViewData["PageTitle"] = "Quản lý Phòng Học";
    var vaiTro = Context.Session.GetString("TenVaiTro");
    var isAdmin = vaiTro == "Quản trị viên" || vaiTro == "Admin" || User.IsInRole("Admin");
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Danh sách phòng học</h1>
        <p>Quản lý, tìm kiếm và cập nhật thông tin các phòng học</p>
    </div>
    <div class="page-header-actions">
        @if (isAdmin)
        {
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>Thêm phòng mới</span>
            </a>
        }
    </div>
</div>

<!-- Filter Bar -->
<div class="card mb-5">
    <div class="card-body">
        <form method="get" asp-action="Index" class="filter-bar" data-loading>
            <div class="filter-group">
                <input type="text" name="searchName" class="form-control" placeholder="🔍 Tìm kiếm tên hoặc mã phòng..." />
            </div>
            <div class="filter-group">
                <select name="dayNha" class="form-control">
                    <option value="">-- Tất cả dãy nhà --</option>
                    <option value="A">Dãy A</option>
                    <option value="B">Dãy B</option>
                    <option value="L">Dãy L</option>
                </select>
            </div>
            <div class="filter-group">
                <select name="loaiPhong" class="form-control">
                    <option value="">-- Loại phòng --</option>
                    <option value="Lý thuyết">Lý thuyết</option>
                    <option value="Thực hành">Thực hành</option>
                    <option value="Seminar">Seminar</option>
                </select>
            </div>
            <div class="filter-group">
                <select name="trangThai" class="form-control">
                    <option value="">-- Trạng thái --</option>
                    <option value="Trống">Trống</option>
                    <option value="Đang sử dụng">Đang sử dụng</option>
                    <option value="Đang bảo trì">Đang bảo trì</option>
                    <option value="Ngừng sử dụng">Ngừng sử dụng</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
                    <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>Tìm kiếm</span>
            </button>
        </form>
    </div>
</div>

<!-- Data Table -->
<div class="card">
    <div class="card-header">
        <div class="card-title">
            <span>📚 Tất cả phòng học (@Model.Count())</span>
        </div>
    </div>
    <div class="card-body" style="padding:0;">
        <div class="table-wrapper">
            <table class="data-table table">
                <thead>
                    <tr>
                        <th>Mã Phòng</th>
                        <th>Tên Phòng</th>
                        <th>Dãy Nhà</th>
                        <th>Tầng</th>
                        <th>Sức Chứa</th>
                        <th>Loại Phòng</th>
                        <th>Trạng Thái</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.MaPhong</strong>
                                </td>
                                <td>@item.TenPhong</td>
                                <td>@item.DayNha</td>
                                <td>@item.Tang</td>
                                <td>@item.SucChua</td>
                                <td>@item.LoaiPhong</td>
                                <td>
                                    @if (item.TrangThai == "Trống")
                                    {
                                        <span class="badge badge-success">✓ Trống</span>
                                    }
                                    else if (item.TrangThai != null && item.TrangThai.StartsWith("Đang sử dụng"))
                                    {
                                        <span class="badge badge-info">● @item.TrangThai</span>
                                    }
                                    else if (item.TrangThai == "Đang bảo trì")
                                    {
                                        <span class="badge badge-warning">⚙ Đang bảo trì</span>
                                    }
                                    else if (item.TrangThai == "Ngừng sử dụng")
                                    {
                                        <span class="badge badge-outline">✕ Ngừng sử dụng</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-outline">@item.TrangThai</span>
                                    }
                                </td>
                                <td>
                                    <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;">
                                        <a href="@Url.Action("Details", new { id = item.MaPhong })" class="btn btn-sm btn-secondary" title="Chi tiết">
                                            👁️
                                        </a>
                                        @if (isAdmin)
                                        {
                                            <a href="@Url.Action("Edit", new { id = item.MaPhong })" class="btn btn-sm btn-secondary" title="Chỉnh sửa">
                                                ✏️
                                            </a>
                                            <form asp-action="NgungSuDung" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@item.MaPhong" />
                                                <button type="submit" class="btn btn-sm btn-danger" title="Ngừng sử dụng" data-confirm="Bạn có chắc muốn ngừng sử dụng phòng này?">
                                                    ⛔
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" style="text-align:center;padding:var(--space-8);">
                                <div style="color:var(--text-sub);font-size:14px;">
                                    📭 Không tìm thấy phòng học nào
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-highlight active nav
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('[data-confirm]').forEach(el => {
                el.addEventListener('click', function (e) {
                    const msg = this.dataset.confirm || 'Bạn có chắc muốn thực hiện thao tác này?';
                    if (!confirm(msg)) e.preventDefault();
                });
            });
        });
    </script>
}
