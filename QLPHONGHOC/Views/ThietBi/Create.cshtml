@model QLPhongHoc.Models.ThietBi
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h3>Thêm thiết bị</h3>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label">Tên thiết bị</label>
            <input asp-for="TenThietBi" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Phòng</label>
            @Html.DropDownListFor(m => m.MaPhong, (SelectList)ViewBag.Phongs, "-- Chọn phòng --", new { @class = "form-select" })
        </div>
        <div class="mb-3">
            <label class="form-label">Số lượng</label>
            <input asp-for="SoLuong" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label class="form-label">Tình trạng</label>
            <input asp-for="TinhTrang" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Ghi chú</label>
            <textarea asp-for="GhiChu" class="form-control"></textarea>
        </div>
        <button class="btn btn-primary">Lưu</button>
        <a class="btn btn-secondary" asp-action="Index">Hủy</a>
    </form>
</div>
