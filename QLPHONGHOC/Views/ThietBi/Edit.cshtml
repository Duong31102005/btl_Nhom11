@model QLPhongHoc.Models.ThietBi
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chỉnh Sửa Thiết Bị";
    ViewData["ActivePage"] = "ThietBi";
    ViewData["PageTitle"] = "Chỉnh Sửa: " + Model.TenThietBi;
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Chỉnh sửa thiết bị</h1>
        <p>Cập nhật thông tin cho thiết bị @Model.MaThietBi</p>
    </div>
</div>

<!-- Form Card -->
<div class="form-card card">
    <div class="card-body">
        <form asp-action="Edit" method="post" novalidate>
            <input type="hidden" asp-for="MaThietBi" />

            <div class="form-section-title">Thông tin thiết bị</div>

            <div class="form-group">
                <label class="form-label" for="tenThietBi">
                    Tên thiết bị <span style="color:var(--accent-danger);">*</span>
                </label>
                <input 
                    asp-for="TenThietBi" 
                    class="form-control" 
                    id="tenThietBi"
                    required />
                <span asp-validation-for="TenThietBi" class="form-text error"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);margin-bottom:var(--space-6);">
                <div class="form-group">
                    <label class="form-label" for="maPhong">
                        Phòng <span style="color:var(--accent-danger);">*</span>
                    </label>
                    <select asp-for="MaPhong" class="form-control" id="maPhong" required>
                        <option value="">-- Chọn phòng --</option>
                        @if (ViewBag.Phongs != null)
                        {
                            @foreach (var phong in (List<SelectListItem>)ViewBag.Phongs)
                            {
                                <option value="@phong.Value" selected="@(phong.Value == Model.MaPhong.ToString())">@phong.Text</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="MaPhong" class="form-text error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="soLuong">
                        Số lượng <span style="color:var(--accent-danger);">*</span>
                    </label>
                    <input 
                        asp-for="SoLuong" 
                        class="form-control" 
                        id="soLuong"
                        type="number" 
                        min="1"
                        required />
                    <span asp-validation-for="SoLuong" class="form-text error"></span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="tinhTrang">
                    Tình trạng <span style="color:var(--accent-danger);">*</span>
                </label>
                <select asp-for="TinhTrang" class="form-control" id="tinhTrang" required>
                    <option value="">-- Chọn tình trạng --</option>
                    <option value="Hoạt động" selected="@(Model.TinhTrang == "Hoạt động")">Hoạt động</option>
                    <option value="Hỏng" selected="@(Model.TinhTrang == "Hỏng")">Hỏng</option>
                    <option value="Đang sửa" selected="@(Model.TinhTrang == "Đang sửa")">Đang sửa</option>
                    <option value="Ngừng sử dụng" selected="@(Model.TinhTrang == "Ngừng sử dụng")">Ngừng sử dụng</option>
                </select>
                <span asp-validation-for="TinhTrang" class="form-text error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="ghiChu">Ghi chú</label>
                <textarea 
                    asp-for="GhiChu" 
                    class="form-control" 
                    id="ghiChu"
                    rows="3"></textarea>
            </div>

            <!-- Actions -->
            <div class="card-footer" style="margin-top:var(--space-8);border:none;background:none;padding:0;">
                <button type="submit" class="btn btn-primary">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                        <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <polyline points="17 21 17 13 7 13 7 21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Lưu Thay Đổi</span>
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <span>Hủy</span>
                </a>
            </div>
        </form>
    </div>
</div>
