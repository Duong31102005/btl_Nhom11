@model QLPhongHoc.Models.ThietBi
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chi Tiết Thiết Bị";
    ViewData["ActivePage"] = "ThietBi";
    ViewData["PageTitle"] = "Chi tiết: " + Model.TenThietBi;
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Chi tiết thiết bị</h1>
        <p>Xem thông tin đầy đủ về thiết bị @Model.MaThietBi</p>
    </div>
    <div class="page-header-actions">
        <a href="@Url.Action("Edit", new { id = Model.MaThietBi })" class="btn btn-primary">
            <span>✏️ Chỉnh Sửa</span>
        </a>
    </div>
</div>

<!-- Detail Card -->
<div class="card" style="max-width:800px;">
    <div class="card-header">
        <div class="card-title">
            <span>@Model.TenThietBi</span>
        </div>
        <div>
            @if (Model.TinhTrang == "Hoạt động")
            {
                <span class="badge badge-success">✓ Hoạt động</span>
            }
            else if (Model.TinhTrang == "Hỏng")
            {
                <span class="badge badge-danger">✕ Hỏng</span>
            }
            else if (Model.TinhTrang == "Đang sửa")
            {
                <span class="badge badge-warning">⚙ Đang sửa</span>
            }
            else if (Model.TinhTrang == "Ngừng sử dụng")
            {
                <span class="badge badge-outline">- Ngừng sử dụng</span>
            }
        </div>
    </div>
    <div class="card-body">
        <div class="detail-grid">
            <!-- Left Column -->
            <div>
                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Mã Thiết Bị</div>
                    <div class="detail-value">@Model.MaThietBi</div>
                </div>

                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Phòng</div>
                    <div class="detail-value">@(Model.PhongHoc?.TenPhong ?? "N/A")</div>
                </div>
            </div>

            <!-- Right Column -->
            <div>
                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Số Lượng</div>
                    <div class="detail-value">@Model.SoLuong</div>
                </div>

                <div class="detail-item" style="margin-bottom:var(--space-6);">
                    <div class="detail-label">Tình Trạng</div>
                    <div class="detail-value">@Model.TinhTrang</div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.GhiChu))
        {
            <div class="divider"></div>
            <div class="form-group">
                <div class="detail-label" style="margin-bottom:var(--space-3);">Ghi Chú</div>
                <div style="background:var(--bg-canvas);padding:var(--space-4);border-radius:var(--radius-md);border-left:3px solid var(--primary-blue);font-size:14px;line-height:1.6;">
                    @Model.GhiChu
                </div>
            </div>
        }
    </div>
    <div class="card-footer">
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <span>← Quay Lại</span>
        </a>
    </div>
</div>
