@model IEnumerable<QLPhongHoc.Models.ThietBi>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý Thiết Bị";
    ViewData["ActivePage"] = "ThietBi";
    ViewData["PageTitle"] = "Quản lý Thiết Bị";
    var vaiTro = Context.Session.GetString("TenVaiTro");
    var isAdmin = vaiTro == "Quản trị viên" || vaiTro == "Admin" || User.IsInRole("Admin");
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Danh sách thiết bị</h1>
        <p>Quản lý thiết bị trong các phòng học</p>
    </div>
    <div class="page-header-actions">
        @if (isAdmin)
        {
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>Thêm Thiết Bị</span>
            </a>
        }
    </div>
</div>

<!-- Filter Bar -->
<div class="card mb-5">
    <div class="card-body">
        <form method="get" asp-action="Index" class="filter-bar" data-loading>
            <div class="filter-group">
                <input type="text" name="searchTerm" class="form-control" placeholder="🔍 Tìm kiếm thiết bị..." />
            </div>
            <div class="filter-group">
                <select name="maPhong" class="form-control">
                    <option value="">-- Tất cả phòng --</option>
                    @if (ViewBag.Phongs != null)
                    {
                        @foreach (var phong in (SelectList)ViewBag.Phongs)
                        {
                            <option value="@phong.Value">@phong.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="filter-group">
                <select name="tinhTrang" class="form-control">
                    <option value="">-- Tất cả tình trạng --</option>
                    <option value="Hoạt động">Hoạt động</option>
                    <option value="Hỏng">Hỏng</option>
                    <option value="Đang sửa">Đang sửa</option>
                    <option value="Ngừng sử dụng">Ngừng sử dụng</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
                    <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>Tìm kiếm</span>
            </button>
        </form>
    </div>
</div>

<!-- Data Table -->
<div class="card">
    <div class="card-header">
        <div class="card-title">
            <span>🔧 Tất cả thiết bị (@Model.Count())</span>
        </div>
    </div>
    <div class="card-body" style="padding:0;">
        <div class="table-wrapper">
            <table class="data-table table">
                <thead>
                    <tr>
                        <th>Mã Thiết Bị</th>
                        <th>Tên Thiết Bị</th>
                        <th>Phòng</th>
                        <th>Số Lượng</th>
                        <th>Tình Trạng</th>
                        <th>Ghi Chú</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.MaThietBi</strong>
                                </td>
                                <td>@item.TenThietBi</td>
                                <td>@item.PhongHoc?.TenPhong ?? "N/A"</td>
                                <td>@item.SoLuong</td>
                                <td>
                                    @if (item.TinhTrang == "Hoạt động")
                                    {
                                        <span class="badge badge-success">✓ Hoạt động</span>
                                    }
                                    else if (item.TinhTrang == "Hỏng")
                                    {
                                        <span class="badge badge-danger">✕ Hỏng</span>
                                    }
                                    else if (item.TinhTrang == "Đang sửa")
                                    {
                                        <span class="badge badge-warning">⚙ Đang sửa</span>
                                    }
                                    else if (item.TinhTrang == "Ngừng sử dụng")
                                    {
                                        <span class="badge badge-outline">- Ngừng sử dụng</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-outline">@item.TinhTrang</span>
                                    }
                                </td>
                                <td>@(item.GhiChu ?? "—")</td>
                                <td>
                                    <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;">
                                        <a href="@Url.Action("Details", new { id = item.MaThietBi })" class="btn btn-sm btn-secondary" title="Chi tiết">
                                            👁️
                                        </a>
                                        @if (isAdmin)
                                        {
                                            <a href="@Url.Action("Edit", new { id = item.MaThietBi })" class="btn btn-sm btn-secondary" title="Chỉnh sửa">
                                                ✏️
                                            </a>
                                            <form asp-action="Delete" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@item.MaThietBi" />
                                                <button type="submit" class="btn btn-sm btn-danger" title="Xóa" data-confirm="Bạn có chắc muốn xóa thiết bị này?">
                                                    🗑️
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" style="text-align:center;padding:var(--space-8);">
                                <div style="color:var(--text-sub);font-size:14px;">
                                    📭 Không tìm thấy thiết bị nào
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
