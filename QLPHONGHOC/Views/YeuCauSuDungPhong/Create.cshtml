@model QLPhongHoc.Models.YeuCauSuDungPhong
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Tạo Yêu Cầu Sử Dụng Phòng";
    ViewData["ActivePage"] = "DangKy";
    ViewData["PageTitle"] = "Tạo Yêu Cầu Mới";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Tạo yêu cầu sử dụng phòng</h1>
        <p>Điền thông tin để đặt phòng học</p>
    </div>
</div>

<!-- Form Card -->
<div class="form-card card">
    <div class="card-body">
        @if (TempData["Error"] != null)
        {
            <div style="background:var(--accent-danger-bg);border-left:4px solid var(--accent-danger);padding:var(--space-4);border-radius:var(--radius-md);margin-bottom:var(--space-6);">
                <div style="color:var(--accent-danger);font-weight:600;">⚠️ Lỗi</div>
                <div style="color:var(--accent-danger);font-size:13px;margin-top:var(--space-1);">@TempData["Error"]</div>
            </div>
        }

        <form asp-action="Create" method="post" novalidate>
            <!-- Thông tin cơ bản -->
            <div class="form-section-title">Thông tin yêu cầu</div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);margin-bottom:var(--space-6);">
                <div class="form-group">
                    <label class="form-label" for="maPhong">
                        Phòng học <span style="color:var(--accent-danger);">*</span>
                    </label>
                    <select asp-for="MaPhong" class="form-control" id="maPhong" required>
                        <option value="">-- Chọn phòng --</option>
                        @if (ViewBag.Phongs != null)
                        {
                            @foreach (var phong in (SelectList)ViewBag.Phongs)
                            {
                                <option value="@phong.Value">@phong.Text</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="MaPhong" class="form-text error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="ngaySuDung">
                        Ngày sử dụng <span style="color:var(--accent-danger);">*</span>
                    </label>
                    <input 
                        asp-for="NgaySuDung" 
                        class="form-control" 
                        id="ngaySuDung"
                        type="date"
                        required />
                    <span asp-validation-for="NgaySuDung" class="form-text error"></span>
                </div>
            </div>

            <!-- Tiết Selector -->
            <div class="form-group">
                <label class="form-label">
                    Tiết sử dụng <span style="color:var(--accent-danger);">*</span>
                </label>
                <div id="tietSelectorContainer" class="tiet-selector"></div>
                <input type="hidden" asp-for="TietBatDau" id="tietBatDau" required />
                <input type="hidden" asp-for="TietKetThuc" id="tietKetThuc" required />
                <span class="form-text" style="color:var(--text-sub);">Chọn tiết bắt đầu rồi chọn tiết kết thúc</span>
            </div>

            <!-- Mục đích -->
            <div class="form-group">
                <label class="form-label" for="mucDich">
                    Mục đích sử dụng <span style="color:var(--accent-danger);">*</span>
                </label>
                <textarea 
                    asp-for="MucDich" 
                    class="form-control" 
                    id="mucDich"
                    placeholder="Mô tả mục đích sử dụng phòng..."
                    rows="4"
                    required></textarea>
                <span asp-validation-for="MucDich" class="form-text error"></span>
            </div>

            <!-- Ghi chú -->
            <div class="form-group">
                <label class="form-label" for="ghiChu">Ghi chú thêm</label>
                <textarea 
                    class="form-control" 
                    id="ghiChu"
                    name="ghiChu"
                    placeholder="Thêm thông tin khác nếu cần..."
                    rows="3"></textarea>
            </div>

            <!-- Actions -->
            <div class="card-footer" style="margin-top:var(--space-8);border:none;background:none;padding:0;">
                <button type="submit" class="btn btn-primary">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                        <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <polyline points="17 21 17 13 7 13 7 21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Gửi Yêu Cầu</span>
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <span>Hủy</span>
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize tiet selector
            TietSelector.init('tietBatDau', 'tietKetThuc', []);
        });
    </script>
}
