@model IEnumerable<QLPhongHoc.Models.YeuCauSuDungPhong>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đặt Phòng Học";
    ViewData["ActivePage"] = "DangKy";
    ViewData["PageTitle"] = "Yêu Cầu Sử Dụng Phòng";
    var isAdmin = Context.Session.GetString("TenVaiTro") == "Quản trị viên";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Yêu cầu sử dụng phòng</h1>
        <p>@(isAdmin ? "Xem và duyệt các yêu cầu sử dụng phòng từ giảng viên" : "Quản lý yêu cầu đặt phòng học của bạn")</p>
    </div>
    @if (!isAdmin)
    {
        <div class="page-header-actions">
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>Tạo Yêu Cầu Mới</span>
            </a>
        </div>
    }
</div>

<!-- Data Table -->
<div class="card">
    <div class="card-header">
        <div class="card-title">
            <span>📅 Danh sách yêu cầu (@Model.Count())</span>
        </div>
    </div>
    <div class="card-body" style="padding:0;">
        <div class="table-wrapper">
            <table class="data-table table">
                <thead>
                    <tr>
                        <th>Mã YC</th>
                        <th>Giảng Viên</th>
                        <th>Phòng</th>
                        <th>Ngày Sử Dụng</th>
                        <th>Tiết</th>
                        <th>Mục Đích</th>
                        <th>Trạng Thái</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach(var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.MaYeuCau</strong>
                                </td>
                                <td>@item.GiangVien?.HoTen ?? "N/A"</td>
                                <td>@item.PhongHoc?.TenPhong ?? "N/A"</td>
                                <td>@item.NgaySuDung.ToString("dd/MM/yyyy")</td>
                                <td>@item.TietBatDau - @item.TietKetThuc</td>
                                <td>@item.MucDich</td>
                                <td>
                                    @if (item.TrangThai == "Chờ duyệt")
                                    {
                                        <span class="badge badge-warning">⏳ Chờ duyệt</span>
                                    }
                                    else if (item.TrangThai == "Đã duyệt")
                                    {
                                        <span class="badge badge-success">✓ Đã duyệt</span>
                                    }
                                    else if (item.TrangThai == "Từ chối")
                                    {
                                        <span class="badge badge-danger">✕ Từ chối</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-outline">@item.TrangThai</span>
                                    }
                                </td>
                                <td>
                                    <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;">
                                        <a href="@Url.Action("Details", new { id = item.MaYeuCau })" class="btn btn-sm btn-secondary">
                                            👁️
                                        </a>
                                        @if (isAdmin && item.TrangThai == "Chờ duyệt")
                                        {
                                            <form asp-action="Approve" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@item.MaYeuCau" />
                                                <button type="submit" class="btn btn-sm btn-success" title="Duyệt">
                                                    ✓
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-danger" title="Từ chối" onclick="showRejectModal('@item.MaYeuCau')">
                                                ✕
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" style="text-align:center;padding:var(--space-8);">
                                <div style="color:var(--text-sub);font-size:14px;">
                                    📭 Không có yêu cầu nào
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal-overlay" id="rejectModal">
    <div class="modal modal-lg">
        <div class="modal-header">
            <h3 class="modal-title">Từ chối yêu cầu</h3>
            <button type="button" class="modal-close" onclick="Modal.close('rejectModal')">×</button>
        </div>
        <form id="rejectForm" method="post" asp-action="Reject">
            <div class="modal-body">
                <input type="hidden" id="rejectId" name="id" />
                <div class="form-group">
                    <label class="form-label">Lý do từ chối</label>
                    <textarea class="form-control" name="lyDoTuChoi" placeholder="Nhập lý do từ chối..." required rows="4"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="Modal.close('rejectModal')">Hủy</button>
                <button type="submit" class="btn btn-danger">Từ Chối</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showRejectModal(id) {
            document.getElementById('rejectId').value = id;
            Modal.open('rejectModal');
        }
    </script>
}
